---
interface Props {
  title: string;
  body: string;
  href: string;
  label: string;
}

const { title, body, href, label } = Astro.props;
---

<section class="surface-panel cta-module fade-up">
  <div>
    <h2>{title}</h2>
    <p class="small-note">{body}</p>
  </div>
  <a class="cta-module__button" href={href}>{label}</a>
</section>

